generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  fullName       String
  email          String   @unique
  role           Role     @default(CONTRIBUTOR)
  department     String
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())
  tasks          Task[]
}

model Sprint {
  id         String   @id @default(uuid())
  name       String
  startDate  DateTime
  endDate    DateTime
  status     SprintStatus @default(ACTIVE)
  tasks      Task[]
}

model Task {
  id           String     @id @default(uuid())
  title        String
  description  String?
  assignedTo   String
  department   String
  sprintId     String
  status       TaskStatus @default(TODO)
  priority     Priority   @default(MEDIUM)
  dueDate      DateTime
  createdAt    DateTime   @default(now())
  completedAt  DateTime?
  assignedUser User       @relation(fields: [assignedTo], references: [id])
  sprint       Sprint     @relation(fields: [sprintId], references: [id])
}

enum Role {
  CONTRIBUTOR
  TEAM_LEAD
  EXECUTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum SprintStatus {
  ACTIVE
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}
